{
  "name": "devops-pipeline-demo",
  "version": "1.0.0",
  "description": "A simple Express app demonstrating a full CI/CD pipeline with DevSecOps practices",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage",
    "test:ci": "jest --coverage --coverageReporters=lcov"
  },
  "keywords": ["devops", "cicd", "docker", "devsecops"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "../coverage",
    "collectCoverageFrom": [
      "*.js"
    ]
  }
}
